#include <Adafruit_GFX.h>    
#include <MCUFRIEND_kbv.h>   
#include <Stepper.h>

MCUFRIEND_kbv tft;

// MANTENEMOS TUS PINES (0 Rx y 1 Tx para sensor, 10-13 para motor)
const int PIN_TRIG = 0;  
const int PIN_ECHO = 1;  
//posiciones de los pines del ULN2003 in1,in3,in2,in4
Stepper motor(2048, 10, 12, 11, 13); 

const int PASOS_POR_REVOLUCION = 2048; 
const float VELOCIDAD_SONIDO = 0.0343;

#define NEGRO       0x0000
#define VERDE       0x07E0
#define VERDE_OSC   0x0320 
#define ROJO        0xF800

int centroX = 160;
int centroY = 120;
int radioMax = 110;
int oldLx = 160;
int oldLy = 120;

void setup() {
  pinMode(PIN_TRIG, OUTPUT);
  pinMode(PIN_ECHO, INPUT);
  motor.setSpeed(8); 
  
  uint16_t ID = tft.readID();
  tft.begin(ID);
  tft.setRotation(1); 
  tft.fillScreen(NEGRO);
  
  dibujarInterfazCompleta();
}

void loop() {
  for (int p = 0; p < PASOS_POR_REVOLUCION; p += 16) {
    motor.step(16);
    float angulo = (p * 360.0) / PASOS_POR_REVOLUCION;
    
    // Mediana de 3 para balance entre velocidad y precisión
    float distancia = obtenerMediana(3); 
    
    actualizarRadarPuntos(angulo, distancia);
  }
  
  // Limpieza al completar 360° para refrescar el mapa
  tft.fillCircle(centroX, centroY, radioMax, NEGRO);
  dibujarInterfazCompleta();
}

void actualizarRadarPuntos(float ang, float dist) {
  float rad = (ang - 90) * PI / 180.0;
  int lx = centroX + cos(rad) * radioMax;
  int ly = centroY + sin(rad) * radioMax;

  // 1. Borrar rastro de la línea anterior
  tft.drawLine(centroX, centroY, oldLx, oldLy, NEGRO);
  
  // 2. REPARAR CUADRÍCULA (Para que no se borre poco a poco)
  repararCuadricula();

  // 3. Dibujar objeto (BARRIDO DE PUNTOS)
  // Ahora el rango es hasta 400 cm
  if (dist > 2 && dist <= 400) {
    int rPunto = map(dist, 0, 400, 0, radioMax);
    int px = centroX + cos(rad) * rPunto;
    int py = centroY + sin(rad) * rPunto;
    
    // Punto gordo para que se vea la silueta
    tft.fillCircle(px, py, 2, ROJO); 
  }

  // 4. Dibujar línea de barrido actual
  tft.drawLine(centroX, centroY, lx, ly, VERDE);

  oldLx = lx;
  oldLy = ly;

  // Telemetría en tiempo real
  tft.fillRect(0, 0, 70, 12, NEGRO);
  tft.setCursor(0, 0);
  tft.setTextColor(VERDE);
  tft.print((int)dist); tft.print("cm");
}

void dibujarInterfazCompleta() {
  repararCuadricula();
  
  // Etiquetas de medida (100, 200, 300, 400 cm)
  tft.setTextSize(1);
  tft.setTextColor(VERDE_OSC);
  tft.setCursor(centroX + (radioMax*0.25) - 5, centroY + 5); tft.print("100");
  tft.setCursor(centroX + (radioMax*0.50) - 5, centroY + 5); tft.print("200");
  tft.setCursor(centroX + (radioMax*0.75) - 5, centroY + 5); tft.print("300");
  tft.setCursor(centroX + radioMax - 20, centroY + 5);       tft.print("400");
}

void repararCuadricula() {
  // Círculos concéntricos
  tft.drawCircle(centroX, centroY, radioMax, VERDE_OSC);
  tft.drawCircle(centroX, centroY, radioMax * 0.75, VERDE_OSC);
  tft.drawCircle(centroX, centroY, radioMax * 0.50, VERDE_OSC);
  tft.drawCircle(centroX, centroY, radioMax * 0.25, VERDE_OSC);
  
  // Ejes principales
  tft.drawLine(centroX - radioMax, centroY, centroX + radioMax, centroY, VERDE_OSC);
  tft.drawLine(centroX, centroY - radioMax, centroX, centroY + radioMax, VERDE_OSC);
}

float obtenerMediana(int n) {
  float lecturas[n];
  for (int i = 0; i < n; i++) {
    digitalWrite(PIN_TRIG, LOW);
    delayMicroseconds(2);
    digitalWrite(PIN_TRIG, HIGH);
    delayMicroseconds(10);
    digitalWrite(PIN_TRIG, LOW);
    
    // Timeout de 24000us (~4 metros de rango)
    long duracion = pulseIn(PIN_ECHO, HIGH, 24000); 
    
    if (duracion == 0) lecturas[i] = 450; 
    else lecturas[i] = (duracion * VELOCIDAD_SONIDO) / 2.0;
    delay(3); // Pausa de estabilización del sensor
  }
  
  // Ordenamiento burbuja para la mediana
  for (int i = 0; i < n-1; i++) {
    for (int j = 0; j < n-i-1; j++) {
      if (lecturas[j] > lecturas[j+1]) {
        float temp = lecturas[j];
        lecturas[j] = lecturas[j+1];
        lecturas[j+1] = temp;
      }
    }
  }
  return lecturas[n/2];
}
